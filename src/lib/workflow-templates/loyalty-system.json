{
  "name": "Система лояльности",
  "description": "Умная система лояльности с проверкой статуса пользователей и флоу регистрации на сайте. Приветственные бонусы начисляются автоматически при активации.",
  "nodes": [
    {
      "id": "start-trigger",
      "type": "trigger.command",
      "position": {
        "x": 100,
        "y": 100
      },
      "data": {
        "label": "Команда /start",
        "command": "/start",
        "description": "Запуск бота"
      }
    },
    {
      "id": "welcome-message",
      "type": "message.text",
      "position": {
        "x": 100,
        "y": 200
      },
      "data": {
        "label": "Приветствие",
        "text": "🎁 Добро пожаловать в программу лояльности!\n\n💰 Получите приветственные бонусы прямо сейчас!\n\n📱 Для регистрации, пожалуйста, поделитесь вашим номером телефона или напишите ваш Email."
      }
    },
    {
      "id": "request-contact",
      "type": "trigger.contact",
      "position": {
        "x": 100,
        "y": 300
      },
      "data": {
        "label": "Запрос контакта",
        "requestPhone": true,
        "buttonText": "📱 Поделиться номером"
      }
    },
    {
      "id": "check-user",
      "type": "action.database_query",
      "position": {
        "x": 100,
        "y": 400
      },
      "data": {
        "label": "Проверка пользователя",
        "config": {
          "action.database_query": {
            "query": "check_user_by_telegram",
            "parameters": {
              "telegramId": "{{telegram.userId}}",
              "phone": "{{contact.phone}}",
              "email": "{{message.text}}"
            },
            "assignTo": "user"
          }
        }
      }
    },
    {
      "id": "is-new-user",
      "type": "condition",
      "position": {
        "x": 100,
        "y": 500
      },
      "data": {
        "label": "Новый пользователь?",
        "config": {
          "condition": {
            "expression": "!get('user') || !get('user').id"
          }
        }
      }
    },
    {
      "id": "create-user",
      "type": "action.database_query",
      "position": {
        "x": -100,
        "y": 600
      },
      "data": {
        "label": "Создать пользователя",
        "config": {
          "action.database_query": {
            "query": "create_user",
            "parameters": {
              "telegramId": "{{telegram.userId}}",
              "username": "{{telegram.username}}",
              "firstName": "{{telegram.firstName}}",
              "phone": "{{contact.phone}}",
              "email": "{{message.text}}"
            },
            "assignTo": "user"
          }
        }
      }
    },
    {
      "id": "add-welcome-bonus",
      "type": "action.database_query",
      "position": {
        "x": -100,
        "y": 700
      },
      "data": {
        "label": "Начислить бонусы",
        "config": {
          "action.database_query": {
            "query": "add_bonus",
            "parameters": {
              "userId": "{{user.id}}",
              "amount": 100,
              "type": "WELCOME",
              "description": "Приветственные бонусы"
            }
          }
        }
      }
    },
    {
      "id": "success-new-user",
      "type": "message.text",
      "position": {
        "x": -100,
        "y": 800
      },
      "data": {
        "label": "Успешная регистрация",
        "text": "🎉 Поздравляем с регистрацией!\n\n💰 Вам начислено 100 приветственных бонусов!\n\n✨ Используйте их для покупок и получайте выгоду!"
      }
    },
    {
      "id": "existing-user-message",
      "type": "message.text",
      "position": {
        "x": 300,
        "y": 600
      },
      "data": {
        "label": "Приветствие существующего",
        "text": "👋 Рады видеть вас снова!\n\n💰 Ваш текущий баланс: {{user.balance}} бонусов\n\n🛍️ Продолжайте делать покупки и копить бонусы!"
      }
    },
    {
      "id": "end-node",
      "type": "flow.end",
      "position": {
        "x": 100,
        "y": 900
      },
      "data": {
        "label": "Завершение",
        "config": {
          "flow.end": {
            "success": true
          }
        }
      }
    }
  ],
  "connections": [
    {
      "id": "start-to-welcome",
      "source": "start-trigger",
      "target": "welcome-message",
      "type": "default"
    },
    {
      "id": "welcome-to-request",
      "source": "welcome-message",
      "target": "request-contact",
      "type": "default"
    },
    {
      "id": "request-to-check",
      "source": "request-contact",
      "target": "check-user",
      "type": "default"
    },
    {
      "id": "check-to-condition",
      "source": "check-user",
      "target": "is-new-user",
      "type": "default"
    },
    {
      "id": "condition-to-create",
      "source": "is-new-user",
      "target": "create-user",
      "type": "true"
    },
    {
      "id": "create-to-bonus",
      "source": "create-user",
      "target": "add-welcome-bonus",
      "type": "default"
    },
    {
      "id": "bonus-to-success",
      "source": "add-welcome-bonus",
      "target": "success-new-user",
      "type": "default"
    },
    {
      "id": "success-to-end",
      "source": "success-new-user",
      "target": "end-node",
      "type": "default"
    },
    {
      "id": "condition-to-existing",
      "source": "is-new-user",
      "target": "existing-user-message",
      "type": "false"
    },
    {
      "id": "existing-to-end",
      "source": "existing-user-message",
      "target": "end-node",
      "type": "default"
    }
  ],
  "variables": [
    {
      "name": "user",
      "type": "object",
      "description": "Данные пользователя из базы данных"
    },
    {
      "name": "welcome_bonus",
      "type": "number",
      "value": 100,
      "description": "Размер приветственного бонуса"
    }
  ],
  "settings": {
    "maxExecutionTime": 60000,
    "retryAttempts": 3
  }
}